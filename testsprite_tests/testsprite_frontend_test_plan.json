  {
    "id": "TC001",
    "title": "Complete onboarding with platforms, writing samples, accepted preview, and successful plan checkout",
    "description": "Verifies the full onboarding happy path from platform selection through accepting the sample preview, selecting a plan, and reaching the dashboard prepared state.",
    "category": "Onboarding Flow",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/onboarding\""
      },
      {
        "type": "action",
        "description": "Click to select the \"X\" platform checkbox"
      },
      {
        "type": "action",
        "description": "Click \"Next\" or \"Continue\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Sample content in your voice\" is visible"
      }
    ]
  },
